# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Firebase credentials — google-services.json is low-sensitivity but no
# reason to publish it; *firebase-adminsdk*.json is a real secret and must
# never be committed.
google-services.json
google-services.dev.json
*firebase-adminsdk*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
